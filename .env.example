POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=predictive_db

# Must use the "timescaledb" scheme (registered by sqlalchemy-timescaledb) so that
# hypertable DDL (create_hypertable) is emitted after CREATE TABLE, both by the app
# engine and by Alembic migrations.
DATABASE_URL=timescaledb://admin:admin123@localhost:5432/predictive_db

LOG_LEVEL=INFO
